{
  globals = {
    mapleader = " ";
  };
  opts = {
    # 行番号を表示するか
    number = true;
    # 行番号を相対表示するか
    relativenumber = true;
    # タブの表示幅
    tabstop = 2;
    # ソフトタブの幅
    softtabstop = 2;
    # インデントの幅
    shiftwidth = 2;
    # タブをスペースに展開するか
    expandtab = true;
    # 自動インデントを使用するか
    smartindent = false;
    # 新しい行を現在の行のインデントと同じにするか
    autoindent = true;
    # 検索時に大文字が含まれる場合のみ大文字と小文字を区別するか
    smartcase = true;
    # 検索時に大文字と小文字を区別しないか
    ignorecase = true;
    # 現在の行をハイライト表示するか
    cursorline = true;
    # 現在の列をハイライト表示するか
    cursorcolumn = true;
    # 検索結果をハイライト表示するか
    hlsearch = true;
    # 検索結果をインクリメンタルハイライト表示するか
    incsearch = true;
    # Floating windowに枠線をつける
    winborder = "single";
  };
}
